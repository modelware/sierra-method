    {
      "height": 480,
      "id": "cbe82d024c0d7cf5",
      "styleAttributes": {
      },
      "text": "```dataviewjs\nlet counts = {};\n\n// Count category occurrences\ndv.pages('#requirement/Requirement and !\"metadata\"')\n  .forEach(p => {\n    let c = p.category || \"Uncategorized\";\n    counts[c] = (counts[c] || 0) + 1;\n  });\n\n// Deterministic color palette (add more as needed)\nconst palette = [\n  'rgb(33, 150, 243)',   // Blue\n  'rgb(76, 175, 80)',    // Green\n  'rgb(255, 193, 7)',    // Amber\n  'rgb(244, 67, 54)',    // Red\n  'rgb(156, 39, 176)',   // Purple\n  'rgb(0, 188, 212)',    // Cyan\n  'rgb(255, 152, 0)',    // Orange\n  'rgb(121, 85, 72)',    // Brown\n  'rgb(63, 81, 181)',    // Indigo\n  'rgb(139, 195, 74)'    // Light Green\n];\n\n// Simple hash function to convert string to a number\nfunction hashStringToIndex(str, mod) {\n  let hash = 0;\n  for (let i = 0; i < str.length; i++) {\n    hash = str.charCodeAt(i) + ((hash << 5) - hash);\n  }\n  return Math.abs(hash) % mod;\n}\n\n// Prepare labels, data, and mapped colors\nlet labels = Object.keys(counts);\nlet data = labels.map(label => counts[label]);\nlet backgroundColors = labels.map((label, i) =>\n  palette[i] || palette[hashStringToIndex(label, palette.length)]\n);\n\n// Build chart config\nconst config = {\n  type: 'pie',\n  data: {\n    labels: labels,\n    datasets: [{\n      label: 'Requirement Categories',\n      data: data,\n      backgroundColor: backgroundColors,\n      hoverOffset: 4\n    }]\n  }\n};\n\nwindow.renderChart(config, this.container);\nthis.container.style.width = \"100%\";\n```\n<p style=\"text-align:center\"> Requirements by Category </p>",
      "type": "text",
      "width": 420,
      "x": -621,
      "y": -783
    }
  ]
